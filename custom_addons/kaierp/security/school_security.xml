<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         Category / privilege
    ══════════════════════════════════════════════════════════ -->
    <data noupdate="0">

        <record id="module_category_school" model="ir.module.category">
            <field name="name">School Management</field>
            <field name="sequence">100</field>
        </record>

        <record id="privilege_school" model="res.groups.privilege">
            <field name="name">School Management</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="kaierp.module_category_school"/>
        </record>

        <!-- Hidden privilege for field-level ACL (implied by roles; not assigned directly) -->
        <record id="module_category_school_fields" model="ir.module.category">
            <field name="name">School Field Access</field>
            <field name="sequence">101</field>
        </record>

        <record id="privilege_school_fields" model="res.groups.privilege">
            <field name="name">School Field Access</field>
            <field name="sequence">101</field>
            <field name="category_id" ref="kaierp.module_category_school_fields"/>
        </record>

    </data>

    <!-- ══════════════════════════════════════════════════════════
         Field-visibility groups (implied by roles)
    ══════════════════════════════════════════════════════════ -->
    <data noupdate="0">

        <record id="group_see_student_basic" model="res.groups">
            <field name="name">See Student: ID &amp; Name</field>
            <field name="privilege_id" ref="kaierp.privilege_school_fields"/>
            <field name="comment">Student ID and display name only.</field>
        </record>

        <record id="group_see_student_academic" model="res.groups">
            <field name="name">See Student: Academic</field>
            <field name="privilege_id" ref="kaierp.privilege_school_fields"/>
            <field name="comment">Class, course, campus, grades, attendance.</field>
            <field name="implied_ids" eval="[(4, ref('kaierp.group_see_student_basic'))]"/>
        </record>

        <record id="group_see_student_full" model="res.groups">
            <field name="name">See Student: Full Profile</field>
            <field name="privilege_id" ref="kaierp.privilege_school_fields"/>
            <field name="comment">Personal, family, church, documents (not fees).</field>
            <field name="implied_ids" eval="[(4, ref('kaierp.group_see_student_academic'))]"/>
        </record>

        <record id="group_see_student_finance_contact" model="res.groups">
            <field name="name">See Student: Finance Contact</field>
            <field name="privilege_id" ref="kaierp.privilege_school_fields"/>
            <field name="comment">Name plus email/phone for billing.</field>
            <field name="implied_ids" eval="[(4, ref('kaierp.group_see_student_basic'))]"/>
        </record>

        <record id="group_see_student_fees" model="res.groups">
            <field name="name">See Student: Fees</field>
            <field name="privilege_id" ref="kaierp.privilege_school_fields"/>
            <field name="comment">Fee lines and balances on the student.</field>
            <field name="implied_ids" eval="[(4, ref('kaierp.group_see_student_basic'))]"/>
        </record>

    </data>

    <!-- ══════════════════════════════════════════════════════════
         Business roles
    ══════════════════════════════════════════════════════════ -->
    <data noupdate="0">

        <!-- Portal student — assign with base.group_portal on the user (not implied here:
             internal staff must never inherit this group alongside Internal User). -->
        <record id="group_school_student" model="res.groups">
            <field name="name">Student</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">Portal learners: own profile, documents, and fees (read-only). Pair with Portal user type.</field>
            <field name="implied_ids" eval="[
                (4, ref('kaierp.group_see_student_full')),
                (4, ref('kaierp.group_see_student_finance_contact')),
                (4, ref('kaierp.group_see_student_fees')),
            ]"/>
        </record>

        <!-- Faculty (keeps xml id group_school_teacher for compatibility) -->
        <record id="group_school_teacher" model="res.groups">
            <field name="name">Faculty</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">Full student profiles except fees. Edit grades, attendance, announcements.</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('kaierp.group_see_student_full')),
                (3, ref('kaierp.group_school_student')),
            ]"/>
        </record>

        <record id="group_school_ta" model="res.groups">
            <field name="name">Teaching Assistant</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">ID, name, class, grades, attendance — view only.</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('kaierp.group_see_student_academic')),
            ]"/>
        </record>

        <record id="group_school_chaplain" model="res.groups">
            <field name="name">Chaplain</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">View students; add Chaplain and Field Education notes/documents.</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('kaierp.group_see_student_basic')),
            ]"/>
        </record>

        <record id="group_school_dean_students" model="res.groups">
            <field name="name">Dean of Students</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">View students; add Chaplain and Field Education notes/documents.</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('kaierp.group_see_student_basic')),
            ]"/>
        </record>

        <record id="group_school_finance" model="res.groups">
            <field name="name">Finance</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">Fees, invoices, payments. Student name/email/phone only.</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('base.group_partner_manager')),
                (4, ref('account.group_account_invoice')),
                (4, ref('kaierp.group_see_student_finance_contact')),
                (4, ref('kaierp.group_see_student_fees')),
            ]"/>
        </record>

        <record id="group_school_registrar" model="res.groups">
            <field name="name">Registrar</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">Office ops + create users. View fees; cannot edit fees or grades.</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('base.group_partner_manager')),
                (4, ref('kaisight.group_kai_view_user')),
                (4, ref('kaierp.group_see_student_full')),
                (4, ref('kaierp.group_see_student_finance_contact')),
                (4, ref('kaierp.group_see_student_fees')),
            ]"/>
        </record>

        <record id="group_school_secretary" model="res.groups">
            <field name="name">Secretary</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">Like Registrar but assigns fees and transcripts; cannot create users or edit grades.</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('base.group_partner_manager')),
                (4, ref('account.group_account_invoice')),
                (4, ref('kaisight.group_kai_view_user')),
                (4, ref('kaierp.group_see_student_full')),
                (4, ref('kaierp.group_see_student_finance_contact')),
                (4, ref('kaierp.group_see_student_fees')),
            ]"/>
        </record>

        <record id="group_school_academic_dean" model="res.groups">
            <field name="name">Academic Dean</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">Full student + fee visibility and reports; Chaplain/Field Education notes and documents.</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('kaisight.group_kai_view_user')),
                (4, ref('kaierp.group_see_student_full')),
                (4, ref('kaierp.group_see_student_finance_contact')),
                (4, ref('kaierp.group_see_student_fees')),
            ]"/>
        </record>

        <record id="group_school_president" model="res.groups">
            <field name="name">President</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">Reports/exports across school data; no edits.</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('kaisight.group_kai_view_user')),
                (4, ref('kaierp.group_see_student_full')),
                (4, ref('kaierp.group_see_student_finance_contact')),
                (4, ref('kaierp.group_see_student_fees')),
            ]"/>
        </record>

        <!-- Full access roles -->
        <record id="group_school_manager" model="res.groups">
            <field name="name">Administrator / Manager</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">School superuser.</field>
            <field name="implied_ids" eval="[
                (4, ref('kaierp.group_school_teacher')),
                (4, ref('kaierp.group_school_registrar')),
                (4, ref('kaierp.group_school_secretary')),
                (4, ref('kaierp.group_school_finance')),
                (4, ref('account.group_account_invoice')),
                (4, ref('kaisight.group_kai_view_manager')),
            ]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_school_it_admin" model="res.groups">
            <field name="name">IT Admin</field>
            <field name="privilege_id" ref="kaierp.privilege_school"/>
            <field name="comment">Full school + technical/settings access.</field>
            <field name="implied_ids" eval="[
                (4, ref('kaierp.group_school_manager')),
                (4, ref('base.group_system')),
            ]"/>
        </record>

    </data>

    <!-- ══════════════════════════════════════════════════════════
         Record rules
    ══════════════════════════════════════════════════════════ -->
    <data noupdate="0">

        <!-- Portal students only see their own linked partner's student record -->
        <record id="rule_school_student_portal_own" model="ir.rule">
            <field name="name">Student: portal own record</field>
            <field name="model_id" ref="model_school_student"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('kaierp.group_school_student'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_school_fee_portal_own" model="ir.rule">
            <field name="name">Fee: portal own fees</field>
            <field name="model_id" ref="model_school_fee"/>
            <field name="domain_force">[('student_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('kaierp.group_school_student'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_school_grade_portal_own" model="ir.rule">
            <field name="name">Grade: portal own grades</field>
            <field name="model_id" ref="model_school_grade"/>
            <field name="domain_force">[('student_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('kaierp.group_school_student'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_school_attendance_portal_own" model="ir.rule">
            <field name="name">Attendance: portal own</field>
            <field name="model_id" ref="model_school_attendance"/>
            <field name="domain_force">[('student_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('kaierp.group_school_student'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>

</odoo>
