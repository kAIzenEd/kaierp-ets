<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_transcript" model="report.paperformat">
        <field name="name">Student Transcript</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">12</field>
        <field name="margin_bottom">12</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_transcript" model="ir.actions.report">
        <field name="name">Generate Transcript</field>
        <field name="model">school.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kaierp.report_student_transcript</field>
        <field name="report_file">kaierp.report_student_transcript</field>
        <field name="print_report_name">'Transcript - %s' % (object.name or object.student_id or 'Student')</field>
        <field name="binding_model_id" ref="model_school_student"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_transcript"/>
    </record>

</odoo>
