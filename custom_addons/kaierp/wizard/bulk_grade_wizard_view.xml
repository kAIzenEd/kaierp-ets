<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_bulk_grade_wizard_form" model="ir.ui.view">
        <field name="name">school.bulk.grade.wizard.form</field>
        <field name="model">school.bulk.grade.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Grade Entry">
                <group>
                    <group>
                        <field name="class_id"       required="1"/>
                        <field name="assessment_type" required="1"/>
                        <field name="date"            required="1"/>
                    </group>
                    <group>
                        <field name="max_score"           required="1"/>
                        <field name="publish_immediately" widget="boolean_toggle"/>
                    </group>
                </group>
                <separator string="Student Grades"/>
                <field name="line_ids" nolabel="1">
                    <list editable="bottom">
                        <field name="student_id" readonly="1"/>
                        <field name="score"/>
                        <field name="remarks"/>
                    </list>
                </field>
                <footer>
                    <button name="action_save_grades" string="Save All Grades"
                            type="object" icon="fa-save" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_school_bulk_grade_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Grade Entry</field>
        <field name="res_model">school.bulk.grade.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>