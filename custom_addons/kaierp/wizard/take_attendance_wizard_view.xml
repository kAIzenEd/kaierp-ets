<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_take_attendance_wizard_form" model="ir.ui.view">
        <field name="name">school.take.attendance.wizard.form</field>
        <field name="model">school.take.attendance.wizard</field>
        <field name="arch" type="xml">
            <form string="Attendance date">
                <group>
                    <field name="class_id" readonly="1"/>
                    <field name="date"/>
                </group>
                
                <footer>
                    <button name="action_open_attendance_sheet" string="Open attendance sheet"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
