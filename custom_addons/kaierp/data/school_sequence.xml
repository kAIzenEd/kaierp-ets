<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_school_student" model="ir.sequence">
            <field name="name">Student ID</field>
            <field name="code">school.student</field>
            <field name="prefix"></field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_school_admission" model="ir.sequence">
            <field name="name">Admission Reference</field>
            <field name="code">school.admission</field>
            <field name="prefix">ADM/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_school_teacher" model="ir.sequence">
            <field name="name">Teacher Employee ID</field>
            <field name="code">school.teacher</field>
            <field name="prefix">TCH/%(year)s/</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_school_registrar" model="ir.sequence">
            <field name="name">Registrar ID</field>
            <field name="code">school.registrar</field>
            <field name="prefix">REG/%(year)s/</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>