<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="kaierp_whatsapp_webhook_verify_token" model="ir.config_parameter">
            <field name="key">kaierp.whatsapp_webhook_verify_token</field>
            <field name="value">change-me-ets-whatsapp-webhook</field>
        </record>

        <record id="kaierp_whatsapp_api_version" model="ir.config_parameter">
            <field name="key">kaierp.whatsapp_api_version</field>
            <field name="value">v21.0</field>
        </record>

        <record id="kaierp_whatsapp_default_country_code" model="ir.config_parameter">
            <field name="key">kaierp.whatsapp_default_country_code</field>
            <field name="value">91</field>
        </record>

        <record id="kaierp_whatsapp_template_language" model="ir.config_parameter">
            <field name="key">kaierp.whatsapp_template_language</field>
            <field name="value">en</field>
        </record>

        <record id="kaierp_whatsapp_template_test" model="ir.config_parameter">
            <field name="key">kaierp.whatsapp_template_test</field>
            <field name="value">hello_world</field>
        </record>

    </data>
</odoo>
