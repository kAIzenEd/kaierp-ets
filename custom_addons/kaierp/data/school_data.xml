<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Email template: notify registrar of new application -->
        <record id="email_template_admission_new_registrar" model="mail.template">
            <field name="name">New Admission — Registrar Notification</field>
            <field name="model_id" ref="model_school_admission"/>
            <field name="subject">New Admission Application: {{ object.reference }} — {{ object.name }}</field>
            <field name="body_html" type="html">
<p>A new admission application has been submitted and is ready for review.</p>
<table style="border-collapse:collapse;width:100%;max-width:560px;">
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Application #</td><td><t t-out="object.reference or ''"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Applicant</td><td><t t-out="object.name or ''"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Course</td><td><t t-out="object.format_selection('course')"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Study mode</td><td><t t-out="object.format_selection('study_mode')"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Email</td><td><t t-out="object.email or ''"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">WhatsApp</td><td><t t-out="object.whatsapp_number or ''"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">City / Country</td>
        <td>
            <t t-out="object.city or ''"/>
            <t t-if="object.country_id">, <t t-out="object.country_id.name"/></t>
        </td>
    </tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Status</td><td><t t-out="object.format_selection('state')"/></td></tr>
</table>
<p style="margin-top:16px;">
    <a t-att-href="'%s/web#id=%s&amp;model=school.admission&amp;view_type=form' % (object.get_base_url(), object.id)"
       style="background:#a11d21;color:#fff;padding:10px 18px;text-decoration:none;border-radius:4px;">
        Open application in Odoo
    </a>
</p>
            </field>
            <field name="lang">{{ object.env.user.lang }}</field>
        </record>

        <!-- Email template: confirm receipt to applicant -->
        <record id="email_template_admission_received_applicant" model="mail.template">
            <field name="name">New Admission — Applicant Confirmation</field>
            <field name="model_id" ref="model_school_admission"/>
            <field name="subject">Application Received — {{ object.reference }} | ETS-ACA</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="body_html" type="html">
<p>Dear <t t-out="object.name or ''"/>,</p>
<p>Thank you for submitting your application to <strong>Evangelical Theological Seminary (ETS-ACA)</strong>.
We have received it and our admissions team will review it shortly.</p>
<table style="border-collapse:collapse;width:100%;max-width:560px;margin:16px 0;">
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Application #</td><td><t t-out="object.reference or ''"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Course</td><td><t t-out="object.format_selection('course')"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Study mode</td><td><t t-out="object.format_selection('study_mode')"/></td></tr>
</table>
<p>If we need any additional information, we will contact you at this email address
or via WhatsApp at <t t-out="object.whatsapp_number or ''"/>.</p>
<p>Questions? Reach our admissions office at
<a href="mailto:etsadmissions@acaindia.org">etsadmissions@acaindia.org</a>.</p>
<p>Best regards,<br/>ETS-ACA Admissions Office</p>
            </field>
            <field name="lang">{{ object.env.user.lang }}</field>
        </record>

        <!-- Email template for admission approval -->
        <record id="email_template_admission_approved" model="mail.template">
            <field name="name">Admission Approved</field>
            <field name="model_id" ref="model_school_admission"/>
            <field name="subject">Your Application to ETS-ACA Has Been Accepted</field>
            <field name="body_html" type="html">
<p>Dear <t t-out="object.name or ''"/>,</p>
<p>We are delighted to inform you that your application
(<strong t-out="object.reference or ''"/>) for
<strong t-out="object.format_selection('course')"/> has been <strong>accepted</strong>.</p>
<p>Please contact our admissions office at etsadmissions@acaindia.org to complete your enrolment.</p>
<p>Welcome to Evangelical Theological Seminary!</p>
            </field>
            <field name="email_to">{{ object.email }}</field>
            <field name="lang">{{ object.env.user.lang }}</field>
        </record>

        <record id="email_template_exam_accommodation_payment" model="mail.template">
            <field name="name">Exam Accommodation — Payment Link</field>
            <field name="model_id" ref="model_school_admission"/>
            <field name="subject">Exam Visit Accommodation Payment — {{ object.reference }} | ETS-ACA</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="body_html" type="html">
<p>Dear <t t-out="object.name or ''"/>,</p>
<p>You have requested on-campus accommodation for your exam visit to
<strong>Evangelical Theological Seminary (ETS-ACA)</strong>.</p>
<table style="border-collapse:collapse;width:100%;max-width:560px;margin:16px 0;">
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Application #</td><td><t t-out="object.reference or ''"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Registration #</td><td><t t-out="object.registration_number or ''"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Nights</td><td><t t-out="object.exam_accommodation_nights or ''"/></td></tr>
    <tr><td style="padding:6px 12px 6px 0;font-weight:bold;">Amount</td><td>₹<t t-out="'%.0f' % (object.exam_accommodation_amount or 0)"/></td></tr>
</table>
<p>Please pay before you arrive on campus. Use the secure Razorpay link below:</p>
<p style="margin-top:16px;">
    <a t-att-href="object.exam_accommodation_payment_link_url"
       style="background:#a11d21;color:#fff;padding:12px 20px;text-decoration:none;border-radius:4px;">
        Pay accommodation fee online
    </a>
</p>
<p class="text-muted">If the button does not work, copy this link into your browser:<br/>
<t t-out="object.exam_accommodation_payment_link_url or ''"/></p>
<p>Questions? Contact admissions at
<a href="mailto:etsadmissions@acaindia.org">etsadmissions@acaindia.org</a>.</p>
<p>Best regards,<br/>ETS-ACA Admissions Office</p>
            </field>
            <field name="lang">{{ object.env.user.lang }}</field>
        </record>

        <!-- Email: request corrected / missing documents via secure upload link -->
        <record id="email_template_admission_document_upload" model="mail.template">
            <field name="name">Admission — Document Upload Request</field>
            <field name="model_id" ref="model_school_admission"/>
            <field name="subject">Documents Needed — {{ object.reference }} | ETS-ACA</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="body_html" type="html">
<p>Dear <t t-out="object.name or ''"/>,</p>
<p>Thank you for your application to
<strong>Evangelical Theological Seminary (ETS-ACA)</strong>
(<t t-out="object.reference or ''"/>).</p>
<p>Our admissions team needs one or more documents corrected or completed.
Please upload them using the secure link below — <strong>no login is required</strong>.</p>
<table style="border-collapse:collapse;width:100%;max-width:560px;margin:16px 0;">
    <t t-foreach="object.document_review_ids.filtered('has_issue')" t-as="doc">
        <tr>
            <td style="padding:6px 12px 6px 0;font-weight:bold;vertical-align:top;">
                <t t-out="doc.document_label or ''"/>
            </td>
            <td style="padding:6px 0;vertical-align:top;">
                <t t-out="doc.review_notes or 'Please upload a clear copy.'"/>
            </td>
        </tr>
    </t>
</table>
<p style="margin-top:16px;">
    <a t-att-href="object.document_upload_url"
       style="background:#a11d21;color:#fff;padding:12px 20px;text-decoration:none;border-radius:4px;">
        Upload documents
    </a>
</p>
<p>If the button does not work, copy this link into your browser:<br/>
<t t-out="object.document_upload_url or ''"/></p>
<p t-if="object.document_upload_token_expiry">
    This link expires on <t t-out="object.document_upload_token_expiry"/>.
</p>
<p>Questions? Contact admissions at
<a href="mailto:etsadmissions@acaindia.org">etsadmissions@acaindia.org</a>.</p>
<p>Best regards,<br/>ETS-ACA Admissions Office</p>
            </field>
            <field name="lang">{{ object.env.user.lang }}</field>
        </record>
    </data>
</odoo>
