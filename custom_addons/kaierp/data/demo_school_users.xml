            <field name="name">Demo Finance</field>
            <field name="login">finance@demo.local</field>
            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_finance"/>
            <field name="group_ids" eval="[(6, 0, [
                ref('base.group_user'),
                ref('kaierp.group_school_finance'),
            ])]"/>
        </record>

        <record id="demo_user_president" model="res.users">
            <field name="name">Demo President</field>
            <field name="login">president@demo.local</field>
            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_president"/>
            <field name="group_ids" eval="[(6, 0, [
