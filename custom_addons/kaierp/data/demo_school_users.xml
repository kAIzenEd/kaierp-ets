<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Demo logins for role testing (password for all: demo)
        faculty@demo.local, ta@demo.local, registrar@demo.local,
        secretary@demo.local, finance@demo.local, president@demo.local,
        academic.dean@demo.local, chaplain@demo.local, dean.students@demo.local,
        it.admin@demo.local, student@demo.local
    -->
    <data noupdate="1">

        <!-- ── Partners ─────────────────────────────────────────── -->
        <record id="demo_partner_faculty" model="res.partner">
            <field name="name">Demo Faculty</field>
            <field name="email">faculty@demo.local</field>
        </record>
        <record id="demo_partner_ta" model="res.partner">
            <field name="name">Demo Teaching Assistant</field>
            <field name="email">ta@demo.local</field>
        </record>
        <record id="demo_partner_registrar" model="res.partner">
            <field name="name">Demo Registrar</field>
            <field name="email">registrar@demo.local</field>
        </record>
        <record id="demo_partner_secretary" model="res.partner">
            <field name="name">Demo Secretary</field>
            <field name="email">secretary@demo.local</field>
        </record>
        <record id="demo_partner_finance" model="res.partner">
            <field name="name">Demo Finance</field>
            <field name="email">finance@demo.local</field>
        </record>
        <record id="demo_partner_president" model="res.partner">
            <field name="name">Demo President</field>
            <field name="email">president@demo.local</field>
        </record>
        <record id="demo_partner_academic_dean" model="res.partner">
            <field name="name">Demo Academic Dean</field>
            <field name="email">academic.dean@demo.local</field>
        </record>
        <record id="demo_partner_chaplain" model="res.partner">
            <field name="name">Demo Chaplain</field>
            <field name="email">chaplain@demo.local</field>
        </record>
        <record id="demo_partner_dean_students" model="res.partner">
            <field name="name">Demo Dean of Students</field>
            <field name="email">dean.students@demo.local</field>
        </record>
        <record id="demo_partner_it_admin" model="res.partner">
            <field name="name">Demo IT Admin</field>
            <field name="email">it.admin@demo.local</field>
        </record>
        <record id="demo_partner_student" model="res.partner">
            <field name="name">Demo Student</field>
            <field name="email">student@demo.local</field>
        </record>

        <!-- ── Internal staff users ──────────────────────────────── -->
        <record id="demo_user_faculty" model="res.users">
            <field name="name">Demo Faculty</field>
            <field name="login">faculty@demo.local</field>
            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_faculty"/>
            <field name="group_ids" eval="[(6, 0, [
                ref('base.group_user'),
                ref('kaierp.group_school_teacher'),
            ])]"/>
        </record>

        <record id="demo_user_ta" model="res.users">
            <field name="name">Demo Teaching Assistant</field>
            <field name="login">ta@demo.local</field>
            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_ta"/>
            <field name="group_ids" eval="[(6, 0, [
                ref('base.group_user'),
                ref('kaierp.group_school_ta'),
            ])]"/>
        </record>

        <record id="demo_user_registrar" model="res.users">
            <field name="name">Demo Registrar</field>
            <field name="login">registrar@demo.local</field>
            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_registrar"/>
            <field name="group_ids" eval="[(6, 0, [
                ref('base.group_user'),
                ref('kaierp.group_school_registrar'),
            ])]"/>
