            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_academic_dean"/>
            <field name="group_ids" eval="[(6, 0, [
                ref('base.group_user'),
                ref('kaierp.group_school_academic_dean'),
            ])]"/>
        </record>

        <record id="demo_user_chaplain" model="res.users">
            <field name="name">Demo Chaplain</field>
            <field name="login">chaplain@demo.local</field>
            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_chaplain"/>
            <field name="group_ids" eval="[(6, 0, [
                ref('base.group_user'),
                ref('kaierp.group_school_chaplain'),
            ])]"/>
        </record>

        <record id="demo_user_dean_students" model="res.users">
            <field name="name">Demo Dean of Students</field>
            <field name="login">dean.students@demo.local</field>
            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_dean_students"/>
            <field name="group_ids" eval="[(6, 0, [
