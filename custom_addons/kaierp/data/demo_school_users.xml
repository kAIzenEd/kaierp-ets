            ])]"/>
        </record>

        <record id="demo_user_it_admin" model="res.users">
            <field name="name">Demo IT Admin</field>
            <field name="login">it.admin@demo.local</field>
            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_it_admin"/>
            <field name="group_ids" eval="[(6, 0, [
                ref('base.group_user'),
                ref('kaierp.group_school_it_admin'),
            ])]"/>
        </record>

        <!-- Portal student (Portal user type + Student group) -->
        <record id="demo_user_student" model="res.users">
            <field name="name">Demo Student</field>
            <field name="login">student@demo.local</field>
            <field name="password">demo</field>
            <field name="partner_id" ref="demo_partner_student"/>
            <field name="group_ids" eval="[(6, 0, [
                ref('base.group_portal'),
                ref('kaierp.group_school_student'),
            ])]"/>
        </record>

        <!-- Linked student profile for portal own-record rule -->
        <record id="demo_school_student" model="school.student">
            <field name="first_name">Demo</field>
            <field name="last_name">Student</field>
            <field name="student_id">DEMO-STU-001</field>
            <field name="date_of_birth">2000-01-15</field>
            <field name="gender">female</field>
            <field name="email">student@demo.local</field>
            <field name="phone_number">+91 90000 00001</field>
            <field name="partner_id" ref="demo_partner_student"/>
            <field name="state">active</field>
            <field name="course">mdiv</field>
            <field name="year_of_study">1st Year</field>
        </record>

    </data>
</odoo>
