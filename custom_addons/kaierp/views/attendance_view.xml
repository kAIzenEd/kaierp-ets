<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Full attendance log (all dates / classes) -->
    <record id="view_school_attendance_list" model="ir.ui.view">
        <field name="name">school.attendance.list</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance" editable="bottom"
                  decoration-danger="state == 'absent'" decoration-warning="state == 'late'">
                <field name="date"/>
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'present'"
                       decoration-danger="state == 'absent'"
                       decoration-warning="state == 'late'"
                       decoration-info="state == 'excused'"/>
                <field name="note"/>
                <field name="teacher_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- In-class session: edit present/absent directly on real attendance records -->
    <record id="view_school_attendance_take_list" model="ir.ui.view">
        <field name="name">school.attendance.take.list</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <list string="Take Attendance" editable="bottom" create="0" delete="0"
                  decoration-danger="state == 'absent'"
                  decoration-warning="state == 'late'"
                  decoration-muted="state == 'excused'">
                <header>
                    <button name="action_session_mark_all_present" type="object"
                            string="All Present" class="btn-primary"/>
                    <button name="action_session_mark_all_absent" type="object"
                            string="All Absent" class="btn-secondary"/>
                    <button name="action_session_mark_all_late" type="object"
                            string="All Late" class="btn-secondary"/>
                    <button name="action_session_mark_all_excused" type="object"
                            string="All Excused" class="btn-secondary"/>
                </header>
                <field name="student_id" readonly="1"/>
                <field name="state"
                       decoration-success="state == 'present'"
                       decoration-danger="state == 'absent'"
                       decoration-warning="state == 'late'"
                       decoration-info="state == 'excused'"/>
                <field name="note"/>
                <field name="class_id" column_invisible="1"/>
                <field name="date" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_school_attendance_form" model="ir.ui.view">
        <field name="name">school.attendance.form</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance">
                <sheet>
                    <group>
                        <field name="student_id"/>
                        <field name="class_id"/>
                        <field name="date"/>
                        <field name="state" widget="radio" options="{'horizontal': true}"/>
                        <field name="note"/>
                        <field name="teacher_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_school_attendance_search" model="ir.ui.view">
        <field name="name">school.attendance.search</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <search string="Attendance">
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="date"/>
                <field name="state"/>
                <filter string="Today" name="today" domain="[('date', '=', 'today')]"/>
                <filter string="Present" name="present" domain="[('state', '=', 'present')]"/>
                <filter string="Absent" name="absent" domain="[('state', '=', 'absent')]"/>
                <group>
                    <filter string="Class" name="group_class" context="{'group_by': 'class_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>



    <record id="action_school_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">school.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_school_attendance_search"/>
    </record>
</odoo>