<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Grade Form View ──────────────────────────────────────── -->
    <record id="view_school_grade_form" model="ir.ui.view">
        <field name="name">school.grade.form</field>
        <field name="model">school.grade</field>
        <field name="arch" type="xml">
            <form string="Grade Entry">
                <header>
                    <button name="action_publish"   string="Publish"   type="object"
                            icon="fa-bullhorn" invisible="is_published" class="btn-primary"/>
                    <button name="action_unpublish" string="Unpublish" type="object"
                            icon="fa-lock" invisible="not is_published" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name_full" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Assessment">
                            <field name="student_id"      required="1"/>
                            <field name="class_id"        required="1"/>
                            <field name="assessment_type" required="1"/>
                            <field name="date"            required="1"/>
                            <field name="weight"/>
                        </group>
                        <group string="Score">
                            <field name="max_score"     required="1"/>
                            <field name="score"         required="1"/>
                            <field name="percentage"    readonly="1" widget="progressbar"/>
                            <field name="letter_grade"  readonly="1"/>
                            <field name="gpa_points"    readonly="1"/>
                            <field name="is_published"  widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Teacher Remarks">
                        <field name="remarks" nolabel="1" placeholder="Remarks / Feedback..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── Grade List View ──────────────────────────────────────── -->
    <record id="view_school_grade_list" model="ir.ui.view">
        <field name="name">school.grade.list</field>
        <field name="model">school.grade</field>
        <field name="arch" type="xml">
            <list string="Grades" editable="bottom"
                  decoration-success="gpa_points >= 3.5"
                  decoration-danger="gpa_points &lt; 1.0">
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="academic_year" readonly="1"/>
                <field name="assessment_type"/>
                <field name="date"/>
                <field name="score"/>
                <field name="max_score"/>
                <field name="percentage" readonly="1" widget="progressbar"/>
                <field name="letter_grade" readonly="1"/>
                <field name="gpa_points"  readonly="1"/>
                <field name="is_published" widget="boolean_toggle"/>
                <button name="action_publish" string="Publish" type="object"
                        icon="fa-eye" invisible="is_published"/>
            </list>
        </field>
    </record>

