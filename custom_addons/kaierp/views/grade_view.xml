    <!-- ─── Grade Graph View (by class) ──────────────────────────── -->
    <record id="view_school_grade_graph" model="ir.ui.view">
        <field name="name">school.grade.graph</field>
        <field name="model">school.grade</field>
        <field name="arch" type="xml">
            <graph string="Grade Distribution" type="bar">
                <field name="class_id" type="row"/>
                <field name="percentage" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ─── Grade Pivot View ─────────────────────────────────────── -->
    <record id="view_school_grade_pivot" model="ir.ui.view">
        <field name="name">school.grade.pivot</field>
        <field name="model">school.grade</field>
        <field name="arch" type="xml">
            <pivot string="Grades Analysis">
                <field name="student_id"      type="row"/>
                <field name="class_id"        type="col"/>
                <field name="gpa_points"      type="measure"/>
                <field name="percentage"      type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ─── Grade Action ─────────────────────────────────────────── -->
    <record id="action_school_grade" model="ir.actions.act_window">
        <field name="name">Grades</field>
        <field name="res_model">school.grade</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No grades recorded yet.</p>
        </field>
    </record>

    <!-- ─── Transcript List View ─────────────────────────────────── -->
    <record id="view_school_transcript_list" model="ir.ui.view">
        <field name="name">school.transcript.list</field>
        <field name="model">school.transcript</field>
        <field name="arch" type="xml">
            <list string="Transcripts" create="0" delete="0" edit="0">
                <field name="student_id"/>
                <field name="academic_year"/>
                <field name="class_id"/>
                <!-- <field name="subject"/> -->
                <field name="credit_hours"/>
                <field name="letter_grade"/>
                <field name="gpa_points"/>
                <field name="weighted_points"/>
            </list>
        </field>
    </record>

    <!-- ─── Transcript Pivot ─────────────────────────────────────── -->
    <record id="view_school_transcript_pivot" model="ir.ui.view">
        <field name="name">school.transcript.pivot</field>
        <field name="model">school.transcript</field>
        <field name="arch" type="xml">
            <pivot string="Transcript Analysis">
                <field name="student_id"    type="row"/>
                <field name="academic_year" type="col"/>
                <field name="weighted_points" type="measure"/>
                <field name="credit_hours"    type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_school_transcript" model="ir.actions.act_window">
        <field name="name">Transcripts</field>
        <field name="res_model">school.transcript</field>
        <field name="view_mode">list,pivot</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No transcript data available.</p>
        </field>
    </record>

</odoo>