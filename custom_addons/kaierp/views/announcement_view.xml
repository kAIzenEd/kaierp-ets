<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_announcement_form" model="ir.ui.view">
        <field name="name">school.announcement.form</field>
        <field name="model">school.announcement</field>
        <field name="arch" type="xml">
            <form string="Announcement">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Announcement Title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_publish"/>
                            <field name="date_expire"/>
                            <field name="audience"/>
                            <field name="priority" widget="priority"/>
                            <field name="is_active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="author_id"/>
                        </group>
                    </group>
                    <separator string="Content"/>
                    <field name="body" placeholder="Announcement content..."/>
                    <separator string="Attachments"/>
                    <field name="attachment_ids" widget="many2many_binary"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_school_announcement_list" model="ir.ui.view">
        <field name="name">school.announcement.list</field>
        <field name="model">school.announcement</field>
        <field name="arch" type="xml">
            <list string="Announcements" decoration-danger="not is_active">
                <field name="priority" widget="priority"/>
                <field name="name"/>
                <field name="audience"/>
                <field name="author_id"/>
                <field name="date_publish"/>
                <field name="date_expire"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_school_announcement" model="ir.actions.act_window">
        <field name="name">Announcements</field>
        <field name="res_model">school.announcement</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>