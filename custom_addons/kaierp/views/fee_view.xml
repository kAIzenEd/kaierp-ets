<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_fee_list" model="ir.ui.view">
        <field name="name">school.fee.list</field>
        <field name="model">school.fee</field>
        <field name="arch" type="xml">
            <list string="Fees"
                  decoration-danger="state == 'overdue'"
                  decoration-success="state == 'paid'">
                <field name="student_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="amount_due"/>
                <field name="amount_paid"/>
                <field name="amount_balance"/>
                <field name="academic_year"/>
                <field name="due_date"/>
                <field name="invoice_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-warning="state in ('partial', 'invoiced')"
                       decoration-danger="state == 'overdue'"
                       decoration-info="state == 'pending'"/>
            </list>
        </field>
    </record>

    <record id="view_school_fee_form" model="ir.ui.view">
        <field name="name">school.fee.form</field>
        <field name="model">school.fee</field>
        <field name="arch" type="xml">
            <form string="Fee">
                <header>
                    <button name="action_create_invoice" string="Create Invoice" type="object"
                            invisible="invoice_id" class="btn-primary"
                            groups="kaierp.group_school_manager"/>
                    <button name="action_view_invoice" string="View Invoice" type="object"
                            invisible="not invoice_id" class="btn-secondary"/>
                    <button name="action_mark_paid" string="Mark as Paid" type="object"
                            invisible="state == 'paid'" class="btn-success"/>
                    <button name="action_waive" string="Waive Fee" type="object"
                            invisible="state in ('paid','waived')" class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,invoiced,paid"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="admission_id" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="product_id"/>
                            <field name="billing_unit"/>
                            <field name="is_refundable"/>
                            <field name="academic_year"/>
                        </group>
                        <group>
                            <field name="quantity"/>
                            <field name="unit_price"/>
                            <field name="amount_due" readonly="1"/>
                            <field name="amount_paid"/>
                            <field name="amount_balance" readonly="1"/>
                            <field name="due_date"/>
                            <field name="payment_date"/>
                            <field name="invoice_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_fee" model="ir.actions.act_window">
        <field name="name">Student Fees</field>
        <field name="res_model">school.fee</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_school_fee_create_combined_invoice" model="ir.actions.server">
        <field name="name">Create Combined Invoice</field>
        <field name="model_id" ref="model_school_fee"/>
        <field name="binding_model_id" ref="model_school_fee"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_create_invoice()</field>
    </record>

    <record id="action_ets_fee_products" model="ir.actions.act_window">
        <field name="name">ETS Fee Catalog</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_ets_fee', '=', True)]</field>
        <field name="context">{'default_is_ets_fee': True, 'default_type': 'service', 'default_sale_ok': True}</field>
    </record>
</odoo>
