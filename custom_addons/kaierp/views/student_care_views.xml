<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_school_student_care_note_form" model="ir.ui.view">
        <field name="name">school.student.care.note.form</field>
        <field name="model">school.student.care.note</field>
        <field name="arch" type="xml">
            <form string="Care Note">
                <group>
                    <field name="student_id" readonly="1"/>
                    <field name="section" readonly="1"/>
                    <field name="note_date"/>
                    <field name="author_id"/>
                </group>
                <separator string="Note"/>
                <field name="note" placeholder="Enter note..." nolabel="1"/>
                <footer>
                    <button string="Save" special="save" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_school_student_care_document_form" model="ir.ui.view">
        <field name="name">school.student.care.document.form</field>
        <field name="model">school.student.care.document</field>
        <field name="arch" type="xml">
            <form string="Care Document">
                <group>
                    <field name="student_id" readonly="1"/>
                    <field name="section" readonly="1"/>
                    <field name="name" placeholder="e.g. Placement report"/>
                    <field name="description" placeholder="Optional"/>
                    <field name="document_file" filename="document_filename"/>
                    <field name="document_filename" invisible="1"/>
                    <field name="upload_date"/>
                    <field name="uploaded_by_id"/>
                </group>
                <footer>
                    <button string="Upload" special="save" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
