<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Student Form View ────────────────────────────────────── -->
    <record id="view_school_student_form" model="ir.ui.view">
        <field name="name">school.student.form</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <form string="Student Profile">
                <header>
                    <button name="action_set_active"    string="Set Active"    type="object"
                            invisible="state == 'active'"
                            class="btn-primary"/>
                    <button name="action_set_graduated" string="Mark Graduated" type="object"
                            invisible="state != 'active'"
                            class="btn-secondary"/>
                    <button name="action_print_transcript" string="Generate Transcript" type="object"
                            icon="fa-file-text-o" class="btn-secondary"
                            groups="kaierp.group_school_secretary,kaierp.group_school_registrar,kaierp.group_school_manager"/>
                    <button name="action_schedule_meeting"  string="Schedule Meeting"  type="object"
                            icon="fa-calendar" class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,on_hold,graduated"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_admission" icon="fa-folder-open-o"
                                invisible="not admission_id">
                            <div class="o_stat_info">
                                <span class="o_stat_value">View</span>
                                <span class="o_stat_text">Application</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_enrollments" icon="fa-book">
                            <field string="Classes"  name="enrollment_count" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_grades" icon="fa-star">
                            <field string="Grades"   name="grade_count"      widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_grades" icon="fa-graduation-cap">
                            <field string="GPA"      name="gpa"              widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_grades" icon="fa-check-circle">
                            <field string="Attend.%" name="attendance_percentage" widget="statinfo"/>
                        </button>
                    </div>

                    <field name="photo" widget="image" class="oe_avatar"
                           options="{'preview_image': 'photo'}"/>

                    <div class="oe_title o_admission_title o_student_title">
                        <div class="o_admission_name_row d-flex flex-wrap align-items-end mb-2">
                            <div class="o_admission_name_field">
                                <label for="first_name" string="First Name"/>
                                <field name="first_name" placeholder="First" nolabel="1"/>
                            </div>
                            <div class="o_admission_name_field o_admission_name_field--middle">
                                <label for="middle_name" string="Middle Name"/>
                                <field name="middle_name" placeholder="Middle" nolabel="1"/>
                            </div>
                            <div class="o_admission_name_field">
                                <label for="last_name" string="Last Name"/>
                                <field name="last_name" placeholder="Last" nolabel="1"/>
                            </div>
                        </div>
                        <field name="name" invisible="1"/>
                        <div class="d-flex flex-wrap align-items-center gap-2 text-muted">
                            <label for="student_id" string="Student ID"/>
                            <field name="student_id" readonly="student_id" nolabel="1" class="oe_inline"/>
                            <span>·</span>
                            <field name="course" nolabel="1" class="oe_inline"/>
                            <span>·</span>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'active'"
                                   decoration-warning="state == 'on_hold'"
                                   decoration-info="state == 'graduated'"
                                   decoration-danger="state in ('expelled','transferred')"/>
                        </div>
                    </div>

                    <group>
                        <group string="Academic Choice">
                            <field name="course"/>
                            <field name="study_mode"/>
                            <field name="year_of_study"/>
                            <field name="ets_campus_location"/>
                            <field name="family_quarters"/>
                            <field name="ata_number"/>
                            <field name="class_id" string="Academic Class"/>
                            <field name="roll_number"/>
                            <field name="admission_id" readonly="1"/>
                        </group>
                        <group string="Enrollment Info">
                            <field name="academic_year"/>
                            <field name="admission_date"/>
                            <field name="graduation_date"/>
                            <field name="partner_id" string="Billing Contact"/>
                            <field name="gpa" readonly="1"/>
                            <field name="attendance_percentage" readonly="1" widget="progressbar"/>
                            <field name="total_fees_due" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Personal" name="personal">
                            <group>
                                <group string="Personal Information">
                                    <field name="title"/>
                                    <field name="first_name"/>
                                    <field name="middle_name"/>
                                    <field name="last_name"/>
                                    <field name="whatsapp_number" widget="phone"/>
                                    <field name="date_of_birth" required="1"/>
                                    <field name="birth_day" readonly="1"/>
                                    <field name="birth_month" readonly="1"/>
                                    <field name="birth_year" readonly="1"/>
                                    <field name="gender" required="1"/>
                                    <field name="nationality"/>
                                    <field name="age"/>
                                    <field name="marital_status"/>
                                    <field name="plan_married_during_study"/>
                                </group>
                                <group string="Other Personal">
                                    <field name="has_children"/>
                                </group>
                            </group>
                        </page>

                        <page string="Contact" name="contact">
                            <group>
                                <group string="Contact Information">
                                    <field name="ets_email" widget="email"/>
                                    <field name="email" widget="email"/>
                                    <field name="phone_number" widget="phone"/>
                                    <field name="mobile_number" widget="phone"/>
                                    <field name="postal_address"/>
                                    <field name="current_residence"/>
                                    <field name="city"/>
                                    <field name="state_name"/>
                                    <field name="zip_code"/>
                                    <field name="country_id"/>
                                </group>
                                <group string="Physical Address">
                                    <field name="has_different_physical_address"/>
                                    <field name="physical_address"
                                           invisible="not has_different_physical_address"/>
                                </group>
                            </group>
                        </page>

                        <page string="Emergency Contact" name="emergency">
                            <group>
                                <group>
                                    <field name="emergency_title"/>
                                    <field name="emergency_name"/>
                                    <field name="emergency_relationship"/>
                                    <field name="emergency_mobile" widget="phone"/>
                                    <field name="emergency_email" widget="email"/>
                                </group>
                            </group>
                        </page>

                        <page string="Church" name="church">
                            <group>
                                <group>
                                    <field name="church_name"/>
                                    <field name="church_location"/>
                                    <field name="church_denomination"/>
                                    <field name="church_ministry_type"/>
                                    <field name="is_ordained"/>
                                    <field name="church_financial_support"/>
                                    <field name="graduated_seminary_last_two_years"/>
                                    <field name="working_for_organisation"/>
                                </group>
                            </group>
                        </page>

                        <page string="References" name="references">
                            <group>
                                <field name="personal_reference_1"
                                       placeholder="Name, address, phone"/>
                                <field name="personal_reference_2"
                                       placeholder="Name, address, phone"/>
                                <field name="personal_reference_3"
                                       placeholder="Name, address, phone"/>
                            </group>
                        </page>

                        <page string="Qualifications" name="qualifications">
                            <group>
                                <group string="Academic Background">
                                    <field name="class_x_year"/>
                                    <field name="diploma_after_class_x"/>
                                    <field name="class_xii_diploma_year"/>
                                    <field name="has_undergraduate_theology"/>
                                    <field name="has_undergraduate_non_theology"/>
                                    <field name="has_postgraduate_theology"/>
                                    <field name="has_postgraduate_non_theology"/>
                                    <field name="has_doctoral_non_theology"/>
                                </group>
                            </group>
                        </page>

                        <page string="Financial" name="financial">
                            <group>
                                <group>
                                    <field name="monthly_support_inr"/>
                                    <field name="monthly_support_usd"/>
                                    <field name="has_financial_sponsor"/>
                                    <field name="financial_supporter_role"/>
                                    <field name="financial_supporter_name"/>
                                    <field name="financial_supporter_relation"/>
                                </group>
                                <group>
                                    <field name="financial_supporter_email" widget="email"/>
                                    <field name="financial_supporter_phone" widget="phone"/>
                                    <field name="financial_supporter_address"/>
                                </group>
                            </group>
                        </page>

                        <page string="Family" name="family">
                            <group>
                                <group>
                                    <field name="father_name"/>
                                    <field name="father_occupation"/>
                                    <field name="mother_name"/>
                                    <field name="mother_occupation"/>
                                    <field name="parents_born_again"/>
                                    <field name="parents_believers"/>
                                </group>
                                <group>
                                    <field name="family_postal_addresses"/>
                                    <field name="family_email_addresses"/>
                                    <field name="family_contact_details"/>
                                </group>
                            </group>
                        </page>

                        <page string="Spiritual" name="spiritual">
                            <group>
                                <group>
                                    <field name="religious_background_birth"/>
                                    <field name="believers_baptism"/>
                                    <field name="called_to_ministry"/>
                                    <field name="read_doctrinal_statement"/>
                                    <field name="agree_doctrinal_statement"/>
                                </group>
                            </group>
                        </page>

                        <page string="Work" name="work">
                            <group>
                                <group>
                                    <field name="currently_employed"/>
                                    <field name="active_christian_ministry"/>
                                    <field name="how_knew_seminary"/>
                                </group>
                            </group>
                        </page>

                        <page string="Health" name="health">
                            <group>
                                <group>
                                    <field name="blood_group"/>
                                    <field name="height_cm"/>
                                    <field name="weight_kg"/>
                                    <field name="allergies"/>
                                    <field name="chronic_illness"/>
                                    <field name="prolonged_medication"/>
                                    <field name="vision_hearing_problem"/>
                                </group>
                                <group>
                                    <field name="uses_tobacco"/>
                                    <field name="uses_intoxicants"/>
                                    <field name="suffers_sleeplessness"/>
                                    <field name="psychiatric_care_history"/>
                                    <field name="other_medical_problems"/>
                                </group>
                            </group>
                        </page>

                        <page string="Classes &amp; Grades" name="academic_records">
                            <separator string="Enrolled Classes"/>
                            <field name="enrollment_ids" mode="list" nolabel="1">
                                <list string="Enrollments" editable="bottom">
                                    <field name="class_id"/>
                                    <field name="teacher_id" readonly="1"/>
                                    <field name="academic_year" readonly="1"/>
                                    <field name="enrollment_date"/>
                                    <field name="state"
                                           widget="badge"
                                           decoration-success="state == 'completed'"
                                           decoration-danger="state in ('dropped','failed')"
                                           decoration-warning="state == 'waitlisted'"/>
                                    <button name="action_drop" string="Drop" type="object"
                                            icon="fa-times" invisible="state != 'enrolled'"/>
                                </list>
                            </field>

                            <separator string="Grades"/>
                            <field name="grade_ids" mode="list" nolabel="1">
                                <list string="Grades" create="0" delete="0">
                                    <field name="class_id"/>
                                    <field name="assessment_type"/>
                                    <field name="date"/>
                                    <field name="score"/>
                                    <field name="max_score"/>
                                    <field name="percentage" widget="progressbar"/>
                                    <field name="letter_grade"/>
                                    <field name="gpa_points"/>
                                    <field name="is_published" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>

                        <page string="Fees" name="fees">
                            <div class="mb-2">
                                <button name="action_create_combined_invoice" type="object"
                                        string="Create Combined Invoice" class="btn-secondary"
                                        icon="fa-file-text-o"
                                        groups="kaierp.group_school_manager,kaierp.group_school_registrar"/>
                            </div>
                            <field name="partner_id" invisible="1"/>
                            <field name="fee_ids" mode="list" nolabel="1">
                                <list string="Fees" editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="amount_due" readonly="1"/>
                                    <field name="amount_paid"/>
                                    <field name="amount_balance" readonly="1"/>
                                    <field name="due_date"/>
                                    <field name="invoice_id" optional="show"/>
                                    <field name="state"
                                           widget="badge"
                                           decoration-success="state == 'paid'"
                                           decoration-warning="state in ('partial', 'invoiced')"
                                           decoration-danger="state == 'overdue'"/>
                                    <button name="action_create_invoice" string="Invoice"
                                            type="object" icon="fa-file-text-o"
                                            invisible="invoice_id"/>
                                    <button name="action_view_invoice" string="View Invoice"
                                            type="object" icon="fa-external-link"
                                            invisible="not invoice_id"/>
                                    <button name="action_mark_paid" string="Mark Paid"
                                            type="object" icon="fa-check"
                                            invisible="state == 'paid'"/>
                                </list>
                            </field>
                        </page>

                        <page string="Attendance" name="attendance">
                            <field name="attendance_ids" mode="list" nolabel="1">
                                <list string="Attendance" editable="bottom" decoration-danger="state == 'absent'">
                                    <field name="date"/>
                                    <field name="class_id"/>
                                    <field name="state"
                                           widget="badge"
                                           decoration-success="state == 'present'"
                                           decoration-warning="state == 'late'"
                                           decoration-info="state == 'excused'"
                                           decoration-danger="state == 'absent'"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>

                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>

                        <page string="Chaplain" name="chaplain">
                            <div class="mb-3"
                                 groups="kaierp.group_school_chaplain,kaierp.group_school_dean_students,kaierp.group_school_academic_dean,kaierp.group_school_manager">
                                <button name="action_add_chaplain_note" type="object"
                                        string="Add Note" class="btn-primary me-2"
                                        icon="fa-plus"/>
                                <button name="action_add_chaplain_document" type="object"
                                        string="Add Document" class="btn-secondary"
                                        icon="fa-upload"/>
                            </div>
                            <separator string="Notes"/>
                            <p class="text-muted">Append-only log. Entries cannot be edited after saving.</p>
                            <field name="chaplain_note_ids" nolabel="1" readonly="1">
                                <list create="0" edit="0" delete="1">
                                    <field name="note_date" string="Date"/>
                                    <field name="author_id" string="Author"/>
                                    <field name="note"/>
                                    <field name="section" column_invisible="1"/>
                                </list>
                            </field>
                            <separator string="Documents"/>
                            <field name="chaplain_document_ids" nolabel="1" readonly="1">
                                <list create="0" edit="0" delete="1">
                                    <field name="upload_date" string="Uploaded"/>
                                    <field name="uploaded_by_id" string="By"/>
                                    <field name="name" string="Title"/>
                                    <field name="description"/>
                                    <field name="document_file" filename="document_filename" string="File"/>
                                    <field name="document_filename" column_invisible="1"/>
                                    <field name="section" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="Field Education" name="field_education">
                            <div class="mb-3"
                                 groups="kaierp.group_school_chaplain,kaierp.group_school_dean_students,kaierp.group_school_academic_dean,kaierp.group_school_manager">
                                <button name="action_add_field_education_note" type="object"
                                        string="Add Note" class="btn-primary me-2"
                                        icon="fa-plus"/>
                                <button name="action_add_field_education_document" type="object"
                                        string="Add Document" class="btn-secondary"
                                        icon="fa-upload"/>
                            </div>
                            <separator string="Notes"/>
                            <p class="text-muted">Append-only log. Entries cannot be edited after saving.</p>
                            <field name="field_education_note_ids" nolabel="1" readonly="1">
                                <list create="0" edit="0" delete="1">
                                    <field name="note_date" string="Date"/>
                                    <field name="author_id" string="Author"/>
                                    <field name="note"/>
                                    <field name="section" column_invisible="1"/>
                                </list>
                            </field>
                            <separator string="Documents"/>
                            <field name="field_education_document_ids" nolabel="1" readonly="1">
                                <list create="0" edit="0" delete="1">
                                    <field name="upload_date" string="Uploaded"/>
                                    <field name="uploaded_by_id" string="By"/>
                                    <field name="name" string="Title"/>
                                    <field name="description"/>
                                    <field name="document_file" filename="document_filename" string="File"/>
                                    <field name="document_filename" column_invisible="1"/>
                                    <field name="section" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── Student List View ────────────────────────────────────── -->
    <record id="view_school_student_list" model="ir.ui.view">
        <field name="name">school.student.list</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <list string="Students" decoration-muted="state != 'active'"
                  decoration-danger="state == 'expelled'">
                <field name="photo"       widget="image" options="{'size': [40, 40]}"/>
                <field name="student_id"/>
                <field name="name"/>
                <field name="course"/>
                <field name="study_mode"/>
                <field name="gender"/>
                <field name="age"/>
                <field name="academic_year"/>
                <field name="enrollment_count"/>
                <field name="gpa"       digits="[5,2]"/>
                <field name="attendance_percentage" widget="progressbar"/>
                <field name="total_fees_due"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'active'"
                       decoration-info="state == 'graduated'"
                       decoration-danger="state == 'expelled'"/>
            </list>
        </field>
    </record>

    <!-- ─── Student Kanban View ──────────────────────────────────── -->
    <record id="view_school_student_kanban" model="ir.ui.view">
        <field name="name">school.student.kanban</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" group_by_tooltip="{'state': 'Students by Status'}">
                <field name="name"/>
                <field name="photo"/>
                <field name="student_id"/>
                <field name="course"/>
                <field name="state"/>
                <field name="gpa"/>
                <field name="enrollment_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('school.student', 'photo', record.id.raw_value)"
                                     alt="Photo" class="o_image_64_cover"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div><field name="student_id"/> · <field name="course"/></div>
                                <div>
                                    <span>GPA: </span><field name="gpa"/>
                                    <span class="ms-2">Classes: </span><field name="enrollment_count"/>
                                </div>
                                <div class="mt-1">
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-info="state == 'graduated'"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── Action ───────────────────────────────────────────────── -->
    <record id="action_school_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">school.student</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No students yet. Add your first student!
            </p>
        </field>
    </record>

</odoo>
