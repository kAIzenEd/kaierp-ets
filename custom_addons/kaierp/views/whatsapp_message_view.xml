<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_school_whatsapp_message_list" model="ir.ui.view">
        <field name="name">school.whatsapp.message.list</field>
        <field name="model">school.whatsapp.message</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Messages" create="0" edit="0">
                <field name="create_date" string="Date"/>
                <field name="direction"/>
                <field name="admission_id"/>
                <field name="phone"/>
                <field name="message_type"/>
                <field name="template_name"/>
                <field name="body"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('sent', 'delivered', 'read', 'received')"
                       decoration-danger="state == 'failed'"
                       decoration-muted="state == 'pending'"/>
                <field name="error_message" optional="hide"/>
                <button name="action_whatsapp_reply" type="object" string="Open chat"
                        icon="fa-whatsapp" invisible="not phone"/>
            </list>
        </field>
    </record>

    <record id="view_school_whatsapp_message_form" model="ir.ui.view">
        <field name="name">school.whatsapp.message.form</field>
        <field name="model">school.whatsapp.message</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Message" create="0" edit="0">
                <header>
                    <button name="action_whatsapp_reply" string="Open conversation" type="object"
                            class="btn-primary" icon="fa-whatsapp" invisible="not phone"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" string="Date"/>
                            <field name="direction"/>
                            <field name="state"/>
                            <field name="admission_id"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="message_type"/>
                            <field name="template_name"/>
                            <field name="meta_message_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="body"/>
                        <field name="error_message" invisible="not error_message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_whatsapp_message" model="ir.actions.act_window">
        <field name="name">WhatsApp Messages</field>
        <field name="res_model">school.whatsapp.message</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_inbound': 1}</field>
    </record>

    <record id="action_school_whatsapp_message_inbound" model="ir.actions.act_window">
        <field name="name">WhatsApp Inbox</field>
        <field name="res_model">school.whatsapp.message</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('direction', '=', 'inbound')]</field>
        <field name="context">{'search_default_inbound': 1}</field>
    </record>

    <record id="view_school_whatsapp_message_search" model="ir.ui.view">
        <field name="name">school.whatsapp.message.search</field>
        <field name="model">school.whatsapp.message</field>
        <field name="arch" type="xml">
            <search string="WhatsApp Messages">
                <field name="phone"/>
                <field name="body"/>
                <field name="admission_id"/>
                <field name="template_name"/>
                <filter name="inbound" string="Replies received" domain="[('direction', '=', 'inbound')]"/>
                <filter name="unlinked" string="No linked admission"
                        domain="[('direction', '=', 'inbound'), ('admission_id', '=', False)]"/>
                <filter name="outbound" string="Sent by us" domain="[('direction', '=', 'outbound')]"/>
                <separator/>
                <filter name="failed" string="Failed" domain="[('state', '=', 'failed')]"/>
                <group>
                    <filter name="group_direction" string="Direction" context="{'group_by': 'direction'}"/>
                    <filter name="group_admission" string="Admission" context="{'group_by': 'admission_id'}"/>
                    <filter name="group_phone" string="Phone" context="{'group_by': 'phone'}"/>
                </group>
            </search>
        </field>
    </record>

    <menuitem id="menu_school_whatsapp_messages"
              name="WhatsApp Log"
              parent="menu_school_comms"
              action="action_school_whatsapp_message"
              sequence="5"
              groups="kaierp.group_school_manager"/>

    <menuitem id="menu_school_whatsapp_inbox"
              name="WhatsApp Inbox"
              parent="menu_school_students"
              action="action_school_whatsapp_message_inbound"
              sequence="3"
              groups="kaierp.group_school_registrar,kaierp.group_school_manager,kaierp.group_school_secretary"/>

</odoo>
